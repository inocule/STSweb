{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://roome-backend.onrender.com/api/:path*" },
    { "source": "/ws",         "destination": "https://roome-backend.onrender.com/ws" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
