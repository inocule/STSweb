# ─── Backend — Copy this to .env and fill in your values ───────────────────────

# Supabase PostgreSQL — Session Pooler connection string (IPv4-compatible for Render)
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# JWT signing secret — use a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Your Vercel frontend URL (no trailing slash) — used by CORS
FRONTEND_URL=https://your-project.vercel.app

# Node environment
NODE_ENV=production

# Port (Render sets this automatically — don't set it in Render's env panel)
# PORT=3000
